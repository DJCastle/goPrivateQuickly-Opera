{
  "manifest_version": 3,
  "name": "Go Private Quickly",
  "short_name": "GPQ",
  "version": "1.0.0",
  "description": "Open a new private/incognito window with one click, with an optional hardened mode that tightens privacy settings for that session.",
  "permissions": [
    "storage",
    "privacy"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/venetian-mask/icon-16.png",
    "32": "icons/venetian-mask/icon-32.png",
    "48": "icons/venetian-mask/icon-48.png",
    "128": "icons/venetian-mask/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/venetian-mask/icon-16.png",
      "32": "icons/venetian-mask/icon-32.png",
      "48": "icons/venetian-mask/icon-48.png",
      "128": "icons/venetian-mask/icon-128.png"
    },
    "default_title": "Open a private window",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "minimum_chrome_version": "109",
  "background": {
    "service_worker": "background.js"
  }
}
